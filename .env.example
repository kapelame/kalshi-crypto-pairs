# Kalshi API (required for live/paper trading with auth)
KALSHI_KEY_ID=your-kalshi-api-key-id
KALSHI_KEY_FILE=./kalshi_private.pem

# EC2 monitoring (optional, for monitor.py)
EC2_HOST=ec2-user@YOUR_EC2_IP
EC2_KEY=~/kalshi-crypto-pairs/kalshi-ec2.pem
EC2_DB=/home/ec2-user/kalshi_live_trader.db

# Email reports (optional, for kalshi_report.py)
REPORT_EMAIL=you@example.com
REPORT_SENDER=you@example.com
AWS_REGION=us-east-1

# Trader paths (optional, for kalshi_report.py on EC2)
TRADER_DB=/home/ec2-user/kalshi_live_trader.db
TRADER_LOG=/home/ec2-user/kalshi_live_trader.log
